# Google OAuth 2.0 credentials
# The Client ID is safe to use in front-end code.
# The Client Secret must ONLY be used in a server-side / backend environment —
# never commit it to source control or include it in browser-facing code.

GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret   # server-side only
